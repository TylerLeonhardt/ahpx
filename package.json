{
	"name": "ahpx",
	"version": "0.1.0",
	"type": "module",
	"description": "Agent Host Protocol CLI — manage AHP server connections, sessions, and agent interactions",
	"license": "MIT",
	"bin": {
		"ahpx": "./dist/bin.js"
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"commander": "^13.1.0",
		"picocolors": "^1.1.1",
		"ws": "^8.18.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/node": "^22.13.10",
		"@types/ws": "^8.5.14",
		"tsup": "^8.4.0",
		"typescript": "^5.8.2",
		"vitest": "^3.0.9"
	}
}
