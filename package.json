{
	"name": "@tylerl0706/ahpx",
	"version": "0.2.21",
	"type": "module",
	"description": "Agent Host Protocol client — use as a library or CLI to manage AHP server connections, sessions, and agent interactions",
	"license": "MIT",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./cli": {
			"import": "./dist/bin.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"ahpx": "./dist/bin.js"
	},
	"files": ["dist", "LICENSE"],
	"repository": {
		"type": "git",
		"url": "https://github.com/TylerLeonhardt/ahpx.git"
	},
	"homepage": "https://github.com/TylerLeonhardt/ahpx#readme",
	"bugs": {
		"url": "https://github.com/TylerLeonhardt/ahpx/issues"
	},
	"keywords": ["ahp", "agent-host-protocol", "cli", "agent", "ai", "websocket", "json-rpc"],
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@microsoft/dev-tunnels-connections": "^1.3.48",
		"@microsoft/dev-tunnels-contracts": "^1.3.48",
		"@microsoft/dev-tunnels-management": "^1.3.48",
		"commander": "^13.1.0",
		"picocolors": "^1.1.1",
		"ws": "^8.18.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/node": "^22.13.10",
		"@types/ws": "^8.5.14",
		"tsup": "^8.4.0",
		"typescript": "^5.8.2",
		"vitest": "^3.0.9"
	}
}
